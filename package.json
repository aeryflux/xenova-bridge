{
  "name": "@aeryflux/xenova-bridge",
  "version": "0.1.0",
  "description": "Natural language interface bridge between users and AeryFlux components",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core/index.ts",
    "./utils": "./src/utils/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsc --outDir dist",
    "start": "node dist/server.js",
    "dev": "npx tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "xenova",
    "transformers",
    "nlp",
    "intent-classification",
    "entity-extraction",
    "aeryflux",
    "globe",
    "natural-language"
  ],
  "author": "AeryFlux",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5"
  },
  "peerDependencies": {
    "@xenova/transformers": "^2.17.0"
  },
  "peerDependenciesMeta": {
    "@xenova/transformers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
